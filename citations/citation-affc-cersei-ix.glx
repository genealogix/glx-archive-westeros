citations:
    citation-affc-cersei-ix:
        source: source-affc
        properties:
            locator: "Cersei IX"
            text_from_source: "Septa Moelle was a white-haired harridan with a face as sharp as an axe and lips pursed in perpetual disapproval."
            accessed: "2026-03-06"
        notes: "Cersei orchestrates Margaery Tyrell's arrest by the Faith Militant. She has Osney Kettleblack confess falsely to Margaery's adultery before the High Sparrow. Cersei then visits Margaery in her cell, and subsequently goes to the Great Sept where she is herself arrested by the Faith after Osney, under torture, implicates her in the murder of the previous High Septon."
