citations:
    citation-affc-cersei-iv:
        source: source-affc
        properties:
            locator: "Cersei IV"
            text_from_source: "It was a slow climb to the top of Visenya's Hill. As the horses labored upward, the queen leaned back against a plump red cushion."
            accessed: "2026-03-06"
        notes: "Cersei visits the new High Septon (the High Sparrow) at the Great Sept of Baelor. She negotiates the revival of the Faith Militant — the Warrior's Sons (the Swords) and the Poor Fellows (the Stars) — in exchange for canceling the crown's debt of 900,674 dragons and securing the High Septon's blessing for King Tommen. She believes she has outmaneuvered the High Sparrow, but has armed religious fanatics with legal authority."
