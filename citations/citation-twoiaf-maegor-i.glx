citations:
    citation-twoiaf-maegor-i:
        source: source-twoiaf
        properties:
            locator: "The Targaryen Kings: Maegor I"
            accessed: "2026-03-06"
        notes: "Maegor the Cruel: came to throne 42 AC after Aenys's death. Tyrannical reign, knighted at 16, wars against the Faith Militant. Multiple wives including Ceryse Hightower and Alys Harroway."
