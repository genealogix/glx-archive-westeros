citations:
    citation-acok-catelyn-v:
        source: source-acok
        properties:
            locator: "Catelyn V"
            text_from_source: "She heard Renly begin a jest, his shadow moving, lifting its sword, black on green, candles guttering, shivering, something was queer, wrong, and then she saw Renly's sword still in its scabbard, sheathed still, but the shadowsword . . ."
            accessed: "2026-03-06"
        notes: "Catelyn witnesses the assassination of Renly Baratheon in his tent at Storm's End. A shadow creature kills him. Brienne is present and accused."
