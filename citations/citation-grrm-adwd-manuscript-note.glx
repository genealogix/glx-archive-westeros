citations:
    citation-grrm-adwd-manuscript-note:
        source: source-grrm-statements
        properties:
            locator: "ADWD manuscript annotation, Cushing Library, Texas A&M University"
            text_from_source: "GRRM's editor Anne Groell wrote in the margin at Coldhands' first appearance: 'Is this Benjen? I think it's Benjen...' with a smiley face. Martin's response, circled in red: 'NO.'"
            accessed: "2026-03-10"
        notes: "Discovered by Reddit user _honeybird who visited the Cushing Library to examine the original ADWD manuscript in January 2015. Reported by Vulture on January 6, 2015. The manuscript is part of GRRM's papers donated to Texas A&M. This is a definitive authorial statement that Coldhands is NOT Benjen Stark in the book canon, though the HBO show later merged the two characters."
