citations:
    citation-agot-eddard-xi:
        source: source-agot
        properties:
            locator: "Eddard XI"
            text_from_source: "Through the high narrow windows of the Red Keep's cavernous throne room, the light of sunset spilled across the floor, laying dark red stripes upon the walls where the heads of dragons had once hung."
            accessed: "2026-03-06"
        notes: "Ned sits the Iron Throne while Robert hunts. Riverlands villagers testify about raids by Gregor Clegane on Sherrer, Wendish Town, and the Mummer's Ford. Ned sends Lord Beric Dondarrion with Thoros of Myr and others to execute Gregor Clegane. Ser Loras Tyrell volunteers but is declined. Ser Robar Royce sent to inform the king."
