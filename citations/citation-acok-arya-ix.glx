citations:
    citation-acok-arya-ix:
        source: source-acok
        properties:
            locator: "Arya IX"
            text_from_source: "'Jaqen is as dead as Arry,' he said sadly, 'and I have promises to keep. Valar morghulis, Arya Stark. Say it again.'"
            accessed: "2026-03-06"
        notes: "Jaqen H'ghar gives Arya an iron coin and says 'Valar morghulis'. He changes his face, revealing his Faceless Man nature. Arya names Jaqen as her third target to force him to help take Harrenhal — Ser Amory Lorch is killed by the Brave Companions' bear. Arya names Jaqen as her third victim to compel his help; he counters by offering to assist taking Harrenhal."
