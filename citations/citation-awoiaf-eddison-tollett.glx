  citation-awoiaf-eddison-tollett:
    source: source-awoiaf
    properties:
      locator: "Eddison Tollett"
      accessed: "2026-03-15"
    notes: "House Tollett, Vale of Arryn culture. Born in the Vale. Aliases: Dolorous Edd, Edd Tollett. Squire from House Tollett, steward of the Night's Watch. Recruited by Yoren. Known for dry, pessimistic humor."
