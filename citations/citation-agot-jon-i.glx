citations:
    citation-agot-jon-i:
        source: source-agot
        properties:
            locator: "Jon I"
            accessed: "2026-03-06"
        notes: "POV: Jon Snow. Welcoming feast for King Robert at Winterfell. Jon observes the royal party's entry. He encounters Tyrion Lannister outside the feast; Tyrion counsels him to wear his bastard status as armor. Jon's direwolf Ghost makes his first significant appearance."
