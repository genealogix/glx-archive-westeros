citations:
    citation-agot-jon-v:
        source: source-agot
        properties:
            locator: "Jon V"
            text_from_source: "You are as hopeless as any boys I have ever trained, Ser Alliser Thorne announced when they had all assembled in the yard."
            accessed: "2026-03-06"
        notes: "Ser Alliser passes eight recruits on to the Lord Commander, including Jon, Pyp (Toad), Grenn (Aurochs), Halder (Stone Head), Matthar (Lover), Jeren (Pimple), and Dareon (Monkey). Jon visits Maester Aemon at night to advocate for Samwell Tarly, arguing Sam should be made a steward rather than killed in training."
