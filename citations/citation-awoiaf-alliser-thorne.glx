citations:
  citation-awoiaf-alliser-thorne:
    source: source-awoiaf
    properties:
      locator: "Alliser Thorne"
      accessed: "2026-03-15"
    notes: "Born 247-248 AC in the Crownlands. House Thorne. Titles: Ser, Master-at-arms at Castle Black and Eastwatch. Fought for House Targaryen during Robert's Rebellion; given the choice of death or taking the black by Tywin Lannister after the Sack of King's Landing."
