citations:
    citation-adwd-reek-ii:
        source: source-adwd
        properties:
            locator: "Reek II"
            text_from_source: "He heard the girls first, barking as they raced for home... Roose Bolton had returned and would want his Reek on hand to serve him."
            accessed: "2026-03-06"
        notes: "Theon/Reek at Barrowton. Roose Bolton takes Reek from Ramsay. Roose reveals Ramsay killed his trueborn son Domeric. Reveals that Stannis has left the Wall and taken Deepwood Motte. Decision made to hold the wedding at Winterfell."
