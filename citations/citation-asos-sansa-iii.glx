    citation-asos-sansa-iii:
        source: source-asos
        properties:
            locator: "Sansa III"
            accessed: "2026-03-15"
        notes: "Sansa's third POV chapter in ASOS. Sansa is married to Tyrion Lannister. As Tyrion's wife, she becomes Lady of Winterfell by claim through the Lannister alliance. Tyrion tells her 'Lady of Winterfell' after the ceremony."
