citations:
    citation-agot-arya-i:
        source: source-agot
        properties:
            locator: "Arya I"
            accessed: "2026-03-06"
        notes: "POV: Arya. Arya struggles with needlework under Septa Mordane. Princess Myrcella joins the sewing lesson. Arya watches Bran and Tommen sparring in the yard with Ser Rodrik. Joffrey refuses live-steel practice with Robb. Sandor Clegane confronts Ser Rodrik. Jon gives Arya the thinly fenced sword Needle before departing."
