citations:
    citation-got-s06e10:
        source: source-got-hbo
        properties:
            locator: "S06E10 — The Winds of Winter"
            text_from_source: "Bran Stark's vision reveals a young Eddard Stark arriving at the Tower of Joy where Lyanna Stark lies dying after giving birth. She whispers to Ned: 'His name is... If Robert finds out, he'll kill him. You know he will. You have to protect him. Promise me, Ned.' The camera cuts from the baby's face to Jon Snow's face, confirming Jon's parentage."
            accessed: "2026-03-10"
        notes: "Season 6 finale of Game of Thrones. First explicit on-screen confirmation that Jon Snow is the son of Lyanna Stark and Rhaegar Targaryen. Directed by Miguel Sapochnik. Aired June 26, 2016."
