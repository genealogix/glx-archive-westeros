citations:
    citation-agot-jon-ii:
        source: source-agot
        properties:
            locator: "Jon II"
            accessed: "2026-03-06"
        notes: "POV: Jon. Jon visits the comatose Bran to say farewell, despite Catelyn's hostility. He says goodbye to Robb in the courtyard. He gives Arya the needle-thin sword and names it 'Needle.' Jon and Ghost depart north with Benjen Stark."
