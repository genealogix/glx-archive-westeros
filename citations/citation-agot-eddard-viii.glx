citations:
    citation-agot-eddard-viii:
        source: source-agot
        properties:
            locator: "Eddard VIII"
            text_from_source: "Robert, I beg of you, hear what you are saying. You are talking of murdering a child."
            accessed: "2026-03-06"
        notes: "Ned confronts Robert about ordering Daenerys killed. Ned resigns as Hand. Ned visits Chataya's brothel to see Robert's bastard daughter Barra. Jaime Lannister ambushes Ned's party in the street; Jory Cassel, Wyl, and Heward are killed; Ned's leg is shattered."
