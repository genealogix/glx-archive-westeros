    citation-twoiaf-long-night:
        source: source-twoiaf
        properties:
            locator: "Ancient History: The Long Night"
            accessed: "2026-03-06"
        notes: "The Long Night: a generation-long winter, the Others, the last hero, the Battle for the Dawn, and Azor Ahai. Also covers the founding of the Night's Watch and the Wall."
