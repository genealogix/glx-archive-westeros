citations:
    citation-twoiaf-garth-greenhand:
        source: source-twoiaf
        properties:
            locator: "The Reach: Garth Greenhand"
            accessed: "2026-03-06"
        notes: "Garth Greenhand: legendary progenitor of the Reach's noble houses. His many children including Garth the Gardener, John the Oak, Gilbert of the Vines, Florys the Fox, Maris the Maid, Brandon of the Bloody Blade, and others."
