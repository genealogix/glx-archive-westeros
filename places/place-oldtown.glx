places:
    place-oldtown:
        name: "Oldtown"
        type: city
        parent: place-the-reach
        notes: "The oldest city in Westeros, located at the mouth of the Honeywine in the southwestern Reach. Home to the Citadel where maesters are trained, and the Starry Sept, the former seat of the Faith. Ruled by House Hightower from the Hightower."
