        properties:
            gender: male
            name:
                fields:
                    given: Eddison
                    surname: Tollett
                    type: "birth"
                value: Eddison Tollett
            alias:
                - value: "Dolorous Edd"
                - value: "Edd Tollett"
            house: "Tollett"
