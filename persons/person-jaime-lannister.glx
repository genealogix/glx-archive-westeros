persons:
    person-jaime-lannister:
        properties:
            gender: male
            name:
                fields:
                    given: Jaime
                    prefix: Ser
                    surname: Lannister
                value: Ser Jaime Lannister
            rin: MH:I164
            alias:
                - value: "The Kingslayer"
            title:
                - value: "Lord Commander of the Kingsguard"
