            born_at: place-kings-landing
            died_on: "300"
            died_at: place-kings-landing
            cause_of_death: "Poisoned at his own wedding feast (the Strangler)"
            title:
                - value: "Prince"
                  date: "FROM 286 TO 298"
                - value: "King of the Andals and the Rhoynar and the First Men"
                  date: "FROM 298 TO 300"
                - value: "Lord of the Seven Kingdoms"
                  date: "FROM 298 TO 300"
            alias:
                - value: "Joff"
