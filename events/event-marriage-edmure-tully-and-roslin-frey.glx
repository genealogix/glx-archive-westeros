events:
    event-marriage-edmure-tully-and-roslin-frey:
        title: "Marriage of Ser Edmure Tully and Roslin Frey"
        type: marriage
        date: "299"
        place: place-the-twins
        participants:
            - person: person-edmure-tully
              role: subject
            - person: person-roslin-frey
