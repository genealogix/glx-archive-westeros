events:
    event-hands-tourney:
        type: tournament
        date: "298"
        place: place-kings-landing
        participants:
            - person: person-sandor-clegane
              role: participant
            - person: person-jaime-lannister
              role: participant
            - person: person-gregor-clegane
              role: participant
            - person: person-loras-tyrell
