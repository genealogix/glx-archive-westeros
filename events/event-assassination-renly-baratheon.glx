events:
    event-assassination-renly-baratheon:
        type: death
        date: "299"
        place: place-storms-end
        participants:
            - person: person-renly-baratheon
              role: subject
            - person: person-stannis-baratheon
              role: instigator
            - person: person-melisandre
              role: agent
            - person: person-catelyn-stark
              role: witness
            - person: person-brienne-tarth
